local function applyBootEffect()
    task.spawn(function()
        local savedEnabled = {}
        for key, value in pairs(Enabled) do
            savedEnabled[key] = value
        end

        -- SHUTDOWN EVERYTHING
        stopSpeedBoost()
        stopLaggerCounter()
        stopFloat()
        stopSpamBat()
