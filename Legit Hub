local function updateStealPathProgress(stage, progress)
    if ProgressLabel then
        ProgressLabel.Text = stage or "READY"
    end
    if ProgressPercentLabel then
        ProgressPercentLabel.Text = (progress and progress > 0) and (tostring(math.floor(progress * 100 + 0.5)) .. "%") or ""
    end
    if ProgressBarFill then
        ProgressBarFill.Size = UDim2.new(math.clamp(progress or 0, 0, 1), 0, 1, 0)
    end
end

local function getCarryAwarePathSpeed(pathStep, pathLength)
    if isCarryingBrainrot() then
        return Values.StealingSpeedValue
    end
    if pathLength and pathStep and pathStep >= math.max(2, math.ceil(pathLength * 0.6)) then
        return Values.StealingSpeedValue
    end
    return Values.StealPathSpeed
end

local function stealMoveToPoint(hrp, current, nextPoint, speed, runId)
    local conn
    conn = RunService.Heartbeat:Connect(function()
        if not stealPathActive or runId ~= stealPathRunId then
            conn:Disconnect()
            hrp.AssemblyLinearVelocity = Vector3.zero
            return
        end
        local pos = hrp.Position
        local target = Vector3.new(current.X, pos.Y, current.Z)
        local dir = target - pos
        local dist = dir.Magnitude
        local stopDist = math.clamp(STEAL_PATH_BASE_STOP - dist * 0.04, STEAL_PATH_MIN_STOP, STEAL_PATH_BASE_STOP)
        if dist <= stopDist then conn:Disconnect() hrp.AssemblyLinearVelocity = Vector3.zero return end
        local moveDir = dist > 0 and dir.Unit or Vector3.zero
        if nextPoint then
            local nextDelta = Vector3.new(nextPoint.X, pos.Y, nextPoint.Z) - pos
            if nextDelta.Magnitude > 0.01 then
                local blended = moveDir + nextDelta.Unit * STEAL_PATH_NEXT_POINT_BIAS
                moveDir = blended.Magnitude > 0 and blended.Unit or moveDir
            end
        end
        if stealLastFlatVel.Magnitude > 0.1 and moveDir.Magnitude > 0 then
            local blended = moveDir * (1 - STEAL_PATH_SMOOTH_FACTOR) + stealLastFlatVel.Unit * STEAL_PATH_SMOOTH_FACTOR
            moveDir = blended.Magnitude > 0 and blended.Unit or moveDir
        end
        local moveSpeed = type(speed) == "function" and speed() or speed
        local vel = Vector3.new(moveDir.X * moveSpeed, hrp.AssemblyLinearVelocity.Y, moveDir.Z * moveSpeed)
        hrp.AssemblyLinearVelocity = vel
        stealLastFlatVel = Vector3.new(vel.X, 0, vel.Z)
    end)
    while stealPathActive and runId == stealPathRunId and
        (Vector3.new(hrp.Position.X, 0, hrp.Position.Z) - Vector3.new(current.X, 0, current.Z)).Magnitude > STEAL_PATH_BASE_STOP do
        RunService.Heartbeat:Wait()
    end
end

local function stealRunPath(path, originPosition, runId)
    local hrp = (Player.Character or Player.CharacterAdded:Wait()):WaitForChild("HumanoidRootPart")
    local totalSteps = math.max(#path * 2, 1)
    local completedSteps = 0
    for i, p in ipairs(path) do
        if not stealPathActive or runId ~= stealPathRunId then return end
        completedSteps += 1
        updateStealPathProgress("AUTO PATH TO BASE", completedSteps / totalSteps)
        local nextP = path[i + 1] and path[i + 1].pos
        stealMoveToPoint(hrp, p.pos, nextP, function()
            return getCarryAwarePathSpeed(i, #path)
        end, runId)
        task.wait(i == #path and 0.12 or 0.03)
    end

    for i = #path - 1, 1, -1 do
        if not stealPathActive or runId ~= stealPathRunId then return end
        completedSteps += 1
        updateStealPathProgress("RETURNING TO BASE", completedSteps / totalSteps)
        local nextP = path[i - 1] and path[i - 1].pos or originPosition
        stealMoveToPoint(hrp, path[i].pos, nextP, function()
            return Values.StealPathReturnSpeed
        end, runId)
        task.wait(0.03)
    end

    if originPosition and stealPathActive and runId == stealPathRunId then
        completedSteps += 1
        updateStealPathProgress("RESTORING ORIGINAL POSITION", completedSteps / totalSteps)
        stealMoveToPoint(hrp, originPosition, nil, function()
            return Values.StealPathReturnSpeed
        end, runId)
    end
end

function startStealPath(path)
    local hrp = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    STEAL_PATH_VELOCITY_SPEED = Values.StealPathSpeed
    STEAL_PATH_SECOND_SPEED = Values.StealPathReturnSpeed
    stealPathRunId += 1
    local currentRunId = stealPathRunId
    stealPathActive = true
    stealLastFlatVel = Vector3.zero
    stealPathStartPosition = hrp.Position
    updateStealPathProgress("AUTO PATH READY", 0.03)
    task.spawn(function()
        stealRunPath(path, stealPathStartPosition, currentRunId)
        if currentRunId ~= stealPathRunId then return end
        stealPathActive = false
        updateStealPathProgress("READY", 0)

        -- Disable both AutoRight and AutoLeft
        Enabled.AutoRight = false
        Enabled.AutoLeft = false
        if VisualSetters.AutoRight then VisualSetters.AutoRight(false, true) end
        if VisualSetters.AutoLeft then VisualSetters.AutoLeft(false, true) end
        if floatButtonReferences.AutoRight then floatButtonReferences.AutoRight(false) end
        if floatButtonReferences.AutoLeft then floatButtonReferences.AutoLeft(false) end
    end)
end
function stopStealPath()
    stealPathRunId += 1
    stealPathActive = false
    local hrp = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    if hrp then hrp.AssemblyLinearVelocity = Vector3.zero end
    stealLastFlatVel = Vector3.zero
    updateStealPathProgress("READY", 0)
end

